aobscanmodule(er_font_sub_getter,eldenring.exe,40 53 48 83 EC 20 8B D9 83 F9 0F 72 18 4C 8D 05 ?? ?? ?? ?? BA FD 00 00 00)
aobscanmodule(er_font_traditional_chinese,eldenring.exe,54 00 72 00 61 00 64 00 69 00 74 00 69 00 6F 00 6E 00 61 00 6C 00 43 00 68 00 69 00 6E 00 65 00 73 00 65 00 00 00)

assert(er_font_main_getter,40 53 48 83 EC 20 8B D9 83 F9 0F 72)
assert(er_font_sub_getter,40 53 48 83 EC 20 8B D9 83 F9 0F 72)

registersymbol(er_font_main_getter)
registersymbol(er_font_sub_getter)
registersymbol(er_font_traditional_chinese)

er_font_main_getter:
  mov rax,er_font_traditional_chinese
  ret
  nop

er_font_sub_getter:
  mov rax,er_font_traditional_chinese
  ret
  nop

[DISABLE]
er_font_main_getter:
  db 40 53 48 83 EC 20 8B D9 83 F9 0F 72

er_font_sub_getter:
  db 40 53 48 83 EC 20 8B D9 83 F9 0F 72

unregistersymbol(er_font_main_getter)
unregistersymbol(er_font_sub_getter)
unregistersymbol(er_font_traditional_chinese)
]]></AssemblerScript>
        </CheatEntry>
      </CheatEntries>
    </CheatEntry>
  </CheatEntries>
  <UserdefinedSymbols/>
</CheatTable>
