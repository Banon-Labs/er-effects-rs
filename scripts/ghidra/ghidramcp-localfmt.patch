diff --git a/mcp-bridge/render.go b/mcp-bridge/render.go
new file mode 100644
index 0000000..cd521b7
--- /dev/null
+++ b/mcp-bridge/render.go
@@ -0,0 +1,243 @@
+package main
+
+import (
+	"bytes"
+	"encoding/json"
+	"fmt"
+	"os"
+	"sort"
+	"strings"
+
+	"github.com/mark3labs/mcp-go/mcp"
+)
+
+// defaultJPDictPath is used when GHIDRA_JP_DICT is unset. It points at the
+// version-controlled dictionary in the er-effects-rs repo so it is easy to grow.
+const defaultJPDictPath = "/home/banon/projects/er-effects-rs/scripts/ghidra/jp-en-dict.json"
+
+// renderResult turns the Ghidra server's raw JSON-RPC result into human-readable
+// MCP text. The old code returned string(raw), which dumped the JSON verbatim --
+// so multi-line fields like decompiled C had their newlines escaped to "\n" and
+// shown literally. This surfaces text-bearing results with REAL newlines and
+// pretty-prints everything else.
+func renderResult(raw json.RawMessage) string {
+	// Case 1: the result is a bare JSON string (e.g. decompile_function_by_address,
+	// whose server method returns a String). Unmarshalling yields real newlines.
+	var s string
+	if err := json.Unmarshal(raw, &s); err == nil {
+		return s
+	}
+
+	// Case 2: the result is a JSON object.
+	var obj map[string]json.RawMessage
+	if err := json.Unmarshal(raw, &obj); err == nil {
+		// 2a: a single dominant text field -> header + the text itself.
+		for _, key := range []string{"decompiled", "listing", "code", "text", "pcode"} {
+			if v, ok := obj[key]; ok {
+				var txt string
+				if json.Unmarshal(v, &txt) == nil {
+					return objHeader(obj, key) + txt
+				}
+			}
+		}
+		// 2b: disassembly instructions array -> aligned listing lines.
+		if v, ok := obj["instructions"]; ok {
+			if listing := renderInstructions(v); listing != "" {
+				return objHeader(obj, "instructions") + listing
+			}
+		}
+	}
+
+	// Fallback: indented JSON is at least readable (arrays/objects with no big
+	// multi-line string fields, where escaped newlines are not a concern).
+	var buf bytes.Buffer
+	if json.Indent(&buf, raw, "", "  ") == nil {
+		return buf.String()
+	}
+	return string(raw)
+}
+
+// objHeader builds a compact "// name=... address=..." prefix from an object's
+// scalar context fields, skipping the field that carries the main text body.
+func objHeader(obj map[string]json.RawMessage, skip string) string {
+	var parts []string
+	for _, k := range []string{"name", "function", "address", "entry"} {
+		if k == skip {
+			continue
+		}
+		if v, ok := obj[k]; ok {
+			var s string
+			if json.Unmarshal(v, &s) == nil && s != "" {
+				parts = append(parts, k+"="+s)
+			}
+		}
+	}
+	if len(parts) == 0 {
+		return ""
+	}
+	return "// " + strings.Join(parts, "  ") + "\n\n"
+}
+
+// renderInstructions formats a disassembly instruction array as aligned lines.
+func renderInstructions(v json.RawMessage) string {
+	var instrs []struct {
+		Address  string `json:"address"`
+		Text     string `json:"text"`
+		Mnemonic string `json:"mnemonic"`
+	}
+	if json.Unmarshal(v, &instrs) != nil {
+		return ""
+	}
+	var b strings.Builder
+	for _, in := range instrs {
+		t := in.Text
+		if t == "" {
+			t = in.Mnemonic
+		}
+		b.WriteString(fmt.Sprintf("%-16s %s\n", in.Address, t))
+	}
+	return b.String()
+}
+
+// ---------------------------------------------------------------------------
+// JP -> EN localization (opt-in via the `translate` tool param)
+// ---------------------------------------------------------------------------
+
+var (
+	jpDict             map[string]string
+	jpKeysByLen        []string // dict keys sorted longest-first for greedy replacement
+	translateDefaultOn bool     // whether `translate` defaults on (dict present, not env-disabled)
+)
+
+// loadJPDict loads the JP->EN dictionary once at startup. It merges two files so
+// machine-generated bulk translations and hand-verified ones stay separate:
+//   <dict>.auto.json  -- regenerable autotranslate output (loaded first)
+//   <dict>            -- hand-verified entries that OVERRIDE the auto ones
+// Missing/invalid files are non-fatal: translation degrades to a no-op.
+func loadJPDict() {
+	path := os.Getenv("GHIDRA_JP_DICT")
+	if path == "" {
+		path = defaultJPDictPath
+	}
+	m := map[string]string{}
+	// Auto file first (lower priority).
+	mergeDictFile(m, strings.TrimSuffix(path, ".json")+".auto.json")
+	// Manual/verified file second so it wins on conflict.
+	mergeDictFile(m, path)
+
+	jpDict = m
+	jpKeysByLen = jpKeysByLen[:0]
+	for k := range m {
+		if k == "_comment" {
+			continue
+		}
+		jpKeysByLen = append(jpKeysByLen, k)
+	}
+	// Longest keys first so multi-character terms win over their substrings.
+	sort.Slice(jpKeysByLen, func(i, j int) bool { return len(jpKeysByLen[i]) > len(jpKeysByLen[j]) })
+
+	// Default translate ON when a dictionary is present; GHIDRA_TRANSLATE forces it either way.
+	translateDefaultOn = len(jpDict) > 0
+	switch strings.ToLower(strings.TrimSpace(os.Getenv("GHIDRA_TRANSLATE"))) {
+	case "off", "0", "false", "no":
+		translateDefaultOn = false
+	case "on", "1", "true", "yes":
+		translateDefaultOn = true
+	}
+}
+
+// mergeDictFile overlays the JSON object at path onto m (later wins). No-op if absent/invalid.
+func mergeDictFile(m map[string]string, path string) {
+	data, err := os.ReadFile(path)
+	if err != nil {
+		return
+	}
+	tmp := map[string]string{}
+	if json.Unmarshal(data, &tmp) != nil {
+		return
+	}
+	for k, v := range tmp {
+		if k == "_comment" {
+			continue
+		}
+		m[k] = v
+	}
+}
+
+// translateJP applies the dictionary to text and appends any leftover Japanese
+// runs so the dictionary is easy to grow ("update it as we find new words").
+func translateJP(text string) string {
+	if len(jpDict) > 0 {
+		for _, k := range jpKeysByLen {
+			text = strings.ReplaceAll(text, k, jpDict[k])
+		}
+	}
+	if rem := findJPRuns(text); len(rem) > 0 {
+		text += "\n\n// [untranslated JP -- add to " + dictPathForNote() + ": " + strings.Join(rem, ", ") + "]"
+	}
+	return text
+}
+
+func dictPathForNote() string {
+	if p := os.Getenv("GHIDRA_JP_DICT"); p != "" {
+		return p
+	}
+	return defaultJPDictPath
+}
+
+func isJP(r rune) bool {
+	switch {
+	case r >= 0x3040 && r <= 0x30FF: // hiragana + katakana
+		return true
+	case r >= 0x4E00 && r <= 0x9FFF: // CJK unified ideographs
+		return true
+	case r >= 0x3400 && r <= 0x4DBF: // CJK extension A
+		return true
+	case r >= 0xFF66 && r <= 0xFF9D: // halfwidth katakana
+		return true
+	}
+	return false
+}
+
+// findJPRuns returns the unique maximal runs of Japanese characters in s.
+func findJPRuns(s string) []string {
+	seen := map[string]bool{}
+	var out []string
+	var cur []rune
+	flush := func() {
+		if len(cur) > 0 {
+			w := string(cur)
+			if !seen[w] {
+				seen[w] = true
+				out = append(out, w)
+			}
+			cur = cur[:0]
+		}
+	}
+	for _, r := range s {
+		if isJP(r) {
+			cur = append(cur, r)
+		} else {
+			flush()
+		}
+	}
+	flush()
+	return out
+}
+
+// applyTranslate runs JP->EN translation over a text tool result's content.
+func applyTranslate(res *mcp.CallToolResult) *mcp.CallToolResult {
+	if res == nil || res.IsError {
+		return res
+	}
+	var sb strings.Builder
+	for _, c := range res.Content {
+		if tc, ok := c.(mcp.TextContent); ok {
+			sb.WriteString(tc.Text)
+		}
+	}
+	if sb.Len() == 0 {
+		return res
+	}
+	return mcp.NewToolResultText(translateJP(sb.String()))
+}
