+// withTranslateParam exposes the `translate` toggle on every (non-custom) tool so JP->EN
+// can be turned off per-call when it defaults on. Custom-handler tools bypass renderResult.
+func withTranslateParam(t toolDef) toolDef {
+	if t.Custom != nil {
+		return t
+	}
+	for _, p := range t.Params {
+		if p.MCPName == "translate" {
+			return t
+		}
+	}
+	np := make([]paramDef, len(t.Params), len(t.Params)+1)
+	copy(np, t.Params)
+	t.Params = append(np, translateParam)
+	return t
+}
