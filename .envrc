# shellcheck shell=bash
# Load local environment fragments for er-effects-rs.
# Env fragments live in ./.envs/*.env and are ignored by git.

# DISABLED (2026-06-18, user-directed): previously this auto-source'd EVERY ./.envs/*.env
# together, which cross-contaminated per-probe configs (e.g. one fragment's
# ER_EFFECTS_*/AUTO_RUNTIME_ENV_FILE leaking into an unrelated run, and stale
# input-block/autoload gates persisting). Each launch now sources ONLY its specific
# fragment explicitly (e.g. `. ./.envs/cold-mount.env && bash .auto/runtime_probe.sh`).
# To re-enable global loading, restore the loop below.
#
# env_dir="$PWD/.envs"
# if [ -d "$env_dir" ]; then
#   for env_file in "$env_dir"/*.env; do
#     [ -e "$env_file" ] || continue
#     set -a
#     # shellcheck source=/dev/null
#     source "$env_file"
#     set +a
#   done
# fi
:
